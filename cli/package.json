{
  "name": "@wordpress-dx/cli",
  "description": "CLI tool for syncing WordPress CodeSnippets, styles, and menus via the REST API",
  "version": "0.1.0",
  "author": "jean-smaug",
  "bin": {
    "wdx": "bin/run.js"
  },
  "bugs": {
    "url": "https://github.com/wordpress-dx/wordpress-dx/issues"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.0",
    "@inquirer/prompts": "^8.5.2",
    "@oclif/core": "^4.11.4",
    "@oclif/plugin-help": "^6.2.50",
    "@oclif/plugin-plugins": "^5.4.72",
    "glob": "13.0.6",
    "got": "^15.0.5"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "25.9.1",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "oclif": "^4",
    "prettier": "3.8.3",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "tsx": "4.22.4",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/wordpress-dx/wordpress-dx",
  "keywords": [
    "oclif"
  ],
  "license": "MPL-2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "wdx",
    "dirname": "wdx",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wordpress-dx/wordpress-dx.git"
  },
  "scripts": {
    "watch": "tsc -b --watch",
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\" --reporter spec --full-trace --verbose",
    "test:env": "dotenvx run -- pnpm test",
    "version": "oclif readme && git add README.md",
    "format": "prettier . --write"
  },
  "types": "dist/index.d.ts",
  "directories": {
    "test": "test"
  }
}
