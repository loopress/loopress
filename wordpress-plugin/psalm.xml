<?xml version="1.0"?>
<psalm
    errorLevel="3"
    phpVersion="8.2"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedBaselineEntry="true"
    findUnusedCode="true"
>
    <projectFiles>
        <directory name="src" />
        <file name="loopress.php" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>

    <stubs>
        <file name="vendor/php-stubs/wordpress-stubs/wordpress-stubs.php" />
        <file name="psalm-stubs.php" />
        <file name="code-snippets-stubs.php" />
        <file name="acf-stubs.php" />
        <file name="wpforms-stubs.php" />
    </stubs>

    <issueHandlers>
        <!-- REST callback methods are invoked indirectly by WordPress via register_rest_route(),
             so Psalm can't trace calls to them, and their required WP_REST_Request $request
             is part of the callback contract even when a given endpoint doesn't read any params. -->
        <PossiblyUnusedMethod>
            <errorLevel type="suppress">
                <directory name="src/Acf/RestApi" />
                <directory name="src/Seo/RestApi" />
                <directory name="src/Dependencies/RestApi" />
                <directory name="src/Update/RestApi" />
                <directory name="src/Snippets/RestApi" />
                <directory name="src/Form/RestApi" />
                <directory name="src/Sentry/RestApi" />
                <directory name="src/Settings/RestApi" />
                <!-- Built exclusively through the PHP-DI container (ContainerFactory, wired up
                     by Plugin.php and each Feature::definitions()): autowiring and
                     $container->make() call these reflectively, which Psalm can't trace back
                     to any literal `new`. -->
                <referencedMethod name="Loopress\Contract\FeatureProvider::definitions" />
                <referencedMethod name="Loopress\Contract\FeatureProvider::moduleClasses" />
                <referencedMethod name="Loopress\Acf\Module\AcfModule::__construct" />
                <referencedMethod name="Loopress\Seo\Module\SeoModule::__construct" />
                <referencedMethod name="Loopress\Dependencies\Infrastructure\LoopressEnvironment::__construct" />
                <referencedMethod name="Loopress\Dependencies\Infrastructure\ComposerRunner::__construct" />
                <referencedMethod name="Loopress\Dependencies\Service\ComposerService::__construct" />
                <referencedMethod name="Loopress\Dependencies\Module\ComposerModule::__construct" />
                <referencedMethod name="Loopress\Update\Module\UpdateCheckModule::__construct" />
                <referencedMethod name="Loopress\Snippets\Module\SnippetModule::__construct" />
                <referencedMethod name="Loopress\Snippets\Service\SnippetMigrationService::__construct" />
                <referencedMethod name="Loopress\Update\Infrastructure\GithubReleaseChecker::__construct" />
                <referencedMethod name="Loopress\Dependencies\Infrastructure\PackagistClient::__construct" />
                <referencedMethod name="Loopress\Form\Module\FormModule::__construct" />
            </errorLevel>
        </PossiblyUnusedMethod>
        <PossiblyUnusedParam>
            <errorLevel type="suppress">
                <directory name="src/Acf/RestApi" />
                <directory name="src/Seo/RestApi" />
                <directory name="src/Dependencies/RestApi" />
                <directory name="src/Update/RestApi" />
                <directory name="src/Snippets/RestApi" />
                <directory name="src/Form/RestApi" />
            </errorLevel>
        </PossiblyUnusedParam>

        <!-- WP_REST_Request::get_param() is typed as nullable by the WordPress stubs, but the
             route's own `args` schema marks these as required, so WordPress rejects the request
             before the callback runs if they're missing. -->
        <PossiblyNullArgument>
            <errorLevel type="suppress">
                <directory name="src/Acf/RestApi" />
                <directory name="src/Seo/RestApi" />
                <directory name="src/Dependencies/RestApi" />
                <directory name="src/Snippets/RestApi" />
                <directory name="src/Form/RestApi" />
            </errorLevel>
        </PossiblyNullArgument>

        <!-- Registered as a `rest_post_dispatch` filter; the return value is consumed by
             WordPress's filter chain, not by any caller Psalm can see. -->
        <PossiblyUnusedReturnValue>
            <errorLevel type="suppress">
                <file name="src/RestCache/Module/RestCacheModule.php" />
            </errorLevel>
        </PossiblyUnusedReturnValue>

        <!-- #[\Override] is a PHP 8.3+ builtin attribute; this project's platform (composer.json,
             config.platform.php) targets 8.2, so it isn't used here despite phpVersion being set. -->
        <MissingOverrideAttribute errorLevel="suppress" />

        <!-- require_once ABSPATH . 'wp-admin/includes/...' paths only resolve inside a real
             WordPress install, which isn't present in this analysis environment. -->
        <MissingFile errorLevel="suppress" />

        <!-- Invoked via a dynamic class-string ("\Loopress\{$feature}\Feature"::bootstrap())
             in loopress.php's Plus-feature loop, which Psalm can't trace back to this call site. -->
        <UnusedClass>
            <errorLevel type="suppress">
                <file name="src/Dependencies/Feature.php" />
                <file name="src/Update/Feature.php" />
                <file name="src/Snippets/Feature.php" />
                <file name="src/Form/Feature.php" />
                <file name="src/Sentry/Feature.php" />
                <file name="src/Settings/Feature.php" />
            </errorLevel>
        </UnusedClass>
    </issueHandlers>
</psalm>
