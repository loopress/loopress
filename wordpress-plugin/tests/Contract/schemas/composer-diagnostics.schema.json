{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress composer diagnostics (REST)",
  "description": "GET /loopress/v1/composer/diagnostics response shape (ComposerService::getDiagnostics()).",
  "type": "object",
  "additionalProperties": false,
  "required": ["php_version", "platform_php", "issues"],
  "properties": {
    "php_version": { "type": "string" },
    "platform_php": { "type": ["string", "null"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
