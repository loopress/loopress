{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress composer fix-platform result (REST)",
  "description": "POST /loopress/v1/composer/fix-platform response shape.",
  "type": "object",
  "additionalProperties": false,
  "required": ["message", "php_version", "platform_php"],
  "properties": {
    "message": { "type": "string" },
    "php_version": { "type": "string" },
    "platform_php": { "type": "string" }
  }
}
