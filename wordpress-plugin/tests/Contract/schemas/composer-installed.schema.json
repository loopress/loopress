{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress installed composer packages (REST)",
  "description": "GET /loopress/v1/composer/installed response shape (ComposerService::getInstalled()).",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "constraint", "version"],
    "properties": {
      "name": { "type": "string" },
      "constraint": { "type": "string" },
      "version": { "type": "string" }
    }
  }
}
