{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress outdated composer packages (REST)",
  "description": "GET /loopress/v1/composer/outdated response shape (ComposerService::getOutdated()).",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "version", "latest"],
    "properties": {
      "name": { "type": "string" },
      "version": { "type": "string" },
      "latest": { "type": "string" }
    }
  }
}
