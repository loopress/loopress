{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress SEO post meta (REST)",
  "description": "GET/POST /loopress/v1/seo/post-meta/{type}[/{slug}] response shape (YoastService/RankMathService::exportPost()).",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "slug", "title"],
  "properties": {
    "meta": { "type": ["object", "array"], "description": "Empty postmeta serializes as a JSON array, not {}: PHP's json_encode([]) can't distinguish an empty list from an empty map." },
    "slug": { "type": "string" },
    "title": { "type": "string" }
  }
}
