{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress snippet migration results (REST)",
  "description": "POST /loopress/v1/snippets/migration/{direction} response shape (SnippetMigrationService::migrate()).",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "status"],
    "properties": {
      "id": { "type": "integer" },
      "status": { "type": "string", "enum": ["migrated", "error"] },
      "error": { "type": "string" },
      "warning": { "type": "string" }
    }
  }
}
