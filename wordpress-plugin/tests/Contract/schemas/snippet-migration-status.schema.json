{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress snippet migration status (REST)",
  "description": "GET /loopress/v1/snippets/migration/{direction} response shape.",
  "type": "object",
  "additionalProperties": false,
  "required": ["sourceActive", "destinationActive", "snippets"],
  "properties": {
    "sourceActive": { "type": "boolean" },
    "destinationActive": { "type": "boolean" },
    "snippets": { "type": "array", "items": { "$ref": "snippet.schema.json" } }
  }
}
