{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Loopress update status (REST)",
  "description": "GET /loopress/v1/update response shape.",
  "type": "object",
  "additionalProperties": false,
  "required": ["current_version", "latest_version", "update_available", "release_url"],
  "properties": {
    "current_version": { "type": "string" },
    "latest_version": { "type": ["string", "null"] },
    "update_available": { "type": "boolean" },
    "release_url": { "type": ["string", "null"] }
  }
}
